HOST=0.0.0.0
PORT=4100
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=imods

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# SFTP settings (set SFTP_ENABLED=true to upload to server)
SFTP_ENABLED=false
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_BASE_PATH=/public_html/modscraft/upload/data

# Local fallback path when SFTP is disabled
LOCAL_UPLOAD_BASE=uploads/modscraft/upload/data
